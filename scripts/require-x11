#!/usr/bin/env bash

source require-colors

if [ -z "${DISPLAY:-}" ]; then
    echo "${C_RED}ERROR: This script must be run inside an X11 session.${C_RESET}" >&2
    exit 1
fi

if [ "${XDG_SESSION_TYPE:-x11}" != "x11" ]; then
    echo "${C_RED}ERROR: This script requires X11, but the current session is ${XDG_SESSION_TYPE:-unknown}.${C_RESET}" >&2
    exit 1
fi

if ! xprop -root >/dev/null 2>&1; then
    echo "${C_RED}ERROR: Could not access the X11 root window.${C_RESET}" >&2
    exit 1
fi
